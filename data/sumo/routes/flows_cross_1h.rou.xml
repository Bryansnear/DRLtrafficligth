<?xml version='1.0' encoding='UTF-8'?>
<routes>
  <vType id='car' accel='2.0' decel='4.5' length='5.0' minGap='2.5' sigma='0.5' maxSpeed='13.9' guiShape='passenger'/>
  <!-- Solo edges válidos en la red actual: E_to_C, S_to_C (entrantes) y C_to_N, C_to_W (salientes) -->
  <!-- Este -> Norte (giro a la derecha) -->
  <flow id='E2N' type='car' from='E_to_C' to='C_to_N' begin='0' end='3600' vehsPerHour='400' departLane='random' departSpeed='max'/>

  <!-- Este -> Oeste (recto) -->
  <flow id='E2W' type='car' from='E_to_C' to='C_to_W' begin='0' end='3600' vehsPerHour='600' departLane='random' departSpeed='max'/>

  <!-- Sur -> Norte (recto) -->
  <flow id='S2N' type='car' from='S_to_C' to='C_to_N' begin='0' end='3600' vehsPerHour='600' departLane='random' departSpeed='max'/>

  <!-- Sur -> Oeste (giro a la izquierda) -->
  <flow id='S2W' type='car' from='S_to_C' to='C_to_W' begin='0' end='3600' vehsPerHour='400' departLane='random' departSpeed='max'/>
</routes>
